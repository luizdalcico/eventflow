# Copie para .env e preencha. NÃO comite o .env (só este .env.example).

# --- Rails ---
# Chave para descriptografar config/credentials.yml.enc (= conteúdo de config/master.key).
RAILS_MASTER_KEY=
# RAILS_ENV=production

# --- Banco de dados (produção) ---
# Senha do PostgreSQL de produção (usada em config/database.yml).
EVENTFLOW_DATABASE_PASSWORD=
# Alternativa: URL de conexão completa, se preferir.
# MY_APP_DATABASE_URL=postgres://user:pass@host:5432/eventflow_production

# --- WhatsApp / RSVP (Twilio) ---
# Liga o disparo real de mensagens. Fica desligado até a aprovação do WhatsApp
# Business: o botão aparece, mas não envia nada. Defina como "true" para ativar.
RSVP_SENDING_ENABLED=
# Credenciais da conta (SECRETAS — nunca comitar).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Remetente: no sandbox use o número abaixo; em produção troque pelo número
# aprovado OU use o Messaging Service (TWILIO_MESSAGING_SERVICE_SID).
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Se definido, o envio usa o Messaging Service e ignora TWILIO_WHATSAPP_FROM.
TWILIO_MESSAGING_SERVICE_SID=
# Content SID do template "rsvp" (Quick Reply com botões Confirmo/Não vou).
# Variáveis: {{1}} convidado, {{2}} nome do evento, {{3}} data + horário.
TWILIO_RSVP_CONTENT_SID=HX955b44865b520c7bfee3e3b38fb63cc1
# Defina como "true" só em dev/teste para pular a validação de assinatura do webhook.
TWILIO_SKIP_SIGNATURE=

# --- Contrato (CONTRATADA: dados que aparecem no cabeçalho/assinatura do PDF) ---
CONTRACT_COMPANY_NAME=ANAILDE COELHO EVENTOS
CONTRACT_COMPANY_CNPJ=16.666.264/0001-19
CONTRACT_COMPANY_ADDRESS=Rua Euzébio de Sousa, 379, Fortaleza/CE
# Comarca do foro de eleição (cláusula 9ª).
CONTRACT_FORUM_CITY=Fortaleza, Estado do Ceará

# --- Tuning (opcional; têm padrões) ---
# WEB_CONCURRENCY=2
# JOB_CONCURRENCY=1
# RAILS_MAX_THREADS=5
# RAILS_LOG_LEVEL=info
# SOLID_QUEUE_IN_PUMA=true
# PORT=3000
