<% content_for :title, "Outras datas - Cerimonial.app" %>

<div class="max-w-3xl mx-auto">
  <%= breadcrumbs ["Eventos", events_path], [event_crumb_label(@event), @event], ["Outras datas", nil] %>
  <div class="mb-6">
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Outras datas</h1>
    <p class="text-gray-500 mt-1">Datas importantes além da data principal (ensaio, prova, etc.)</p>
  </div>

  <%= render "event_dates/form", event: @event, event_date: @event_date %>

  <div class="mt-6 space-y-2">
    <div id="event_dates" class="space-y-2">
      <%= render partial: "event_dates/event_date", collection: @event_dates, as: :event_date, locals: { event: @event } %>
    </div>
    <% if @event_dates.empty? %>
      <div id="event_dates_empty" class="bg-white rounded-xl ring-1 ring-gray-200 text-center py-12 text-gray-500 text-sm">
        Nenhuma data adicional ainda. Adicione a primeira acima.
      </div>
    <% end %>
  </div>
</div>
