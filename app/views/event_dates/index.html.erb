<% content_for :title, "Outras datas - Cerimonial.app" %>

<%= breadcrumbs ["Eventos", events_path], [event_crumb_label(@event), @event], ["Outras datas", nil] %>
<div class="mb-6 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
  <div>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Outras datas</h1>
    <p class="text-gray-500 mt-1">Datas importantes além da data principal (ensaio, prova, etc.)</p>
  </div>
  <% if DateTemplate.available_for?(@event.event_type) %>
    <%= button_to "Aplicar template de datas", apply_template_event_event_dates_path(@event),
          data: { turbo_confirm: "Adicionar as datas-padrão de #{translate_event_type(@event.event_type)}? Datas já existentes não são duplicadas." },
          class: "shrink-0 px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-medium text-sm cursor-pointer whitespace-nowrap" %>
  <% end %>
</div>

<%= render "event_dates/form", event: @event, event_date: @event_date %>

<div class="mt-6 space-y-2">
  <%= render "event_dates/list", event: @event, event_dates: @event_dates %>
  <% if @event_dates.empty? %>
    <div id="event_dates_empty" class="bg-white rounded-xl ring-1 ring-gray-200 text-center py-12 text-gray-500 text-sm">
      Nenhuma data adicional ainda. Adicione a primeira acima.
    </div>
  <% end %>
</div>
