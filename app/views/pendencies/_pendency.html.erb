<%# Uma pendência (edição inline + remover). Locals: event, pendency. %>
<%= form_with model: [event, pendency], id: dom_id(pendency),
      data: { controller: "autosave" },
      class: "bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-3 space-y-2" do |f| %>
  <%= f.hidden_field :meeting_id %>
  <div class="flex items-center gap-3">
    <%= f.text_field :description, data: { action: "input->autosave#save" },
          class: "flex-1 min-w-0 bg-transparent border-0 px-2 py-1 text-sm text-gray-800 focus:bg-blue-50 focus:outline-none rounded" %>
    <%= link_to "×", [event, pendency], title: "Remover",
          data: { turbo_method: :delete, turbo_confirm: "Remover esta pendência?", confirm_label: "Remover" },
          class: "shrink-0 text-gray-400 hover:text-red-600 text-lg leading-none px-1" %>
  </div>
  <div class="flex flex-wrap items-center gap-2">
    <%= f.text_field :assignee, placeholder: "Responsável", data: { action: "input->autosave#save" },
          class: "w-40 bg-transparent border border-gray-200 px-2 py-1 text-sm text-gray-600 focus:bg-blue-50 focus:outline-none rounded" %>
    <%= f.select :event_provider_id, event_providers_for_select(event),
          { include_blank: "Fornecedor" },
          data: { action: "change->autosave#save" },
          class: "bg-transparent border border-gray-200 px-2 py-1 text-sm text-gray-600 focus:bg-blue-50 focus:outline-none rounded" %>
    <%= f.select :status, pendency_status_options, {},
          data: { action: "change->autosave#save" },
          class: "bg-transparent border border-gray-200 px-2 py-1 text-sm text-gray-600 focus:bg-blue-50 focus:outline-none rounded" %>
    <%= f.date_field :due_date, data: { action: "change->autosave#save" },
          class: "w-36 bg-transparent border border-gray-200 px-2 py-1 text-sm text-gray-600 focus:bg-blue-50 focus:outline-none rounded" %>
  </div>
<% end %>
