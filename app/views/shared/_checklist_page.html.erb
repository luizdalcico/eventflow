<%# Página de checklist. Locals: event, title, items, item (novo). %>
<div class="max-w-3xl mx-auto">
  <%= breadcrumbs ["Eventos", events_path], [event_crumb_label(event), event], [title, nil] %>
  <div class="mb-6">
    <div class="flex items-center justify-between gap-3">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900"><%= title %></h1>
      <span class="text-sm text-gray-500 shrink-0">
        <%= items.count(&:completed?) %>/<%= items.size %> concluídas
      </span>
    </div>
  </div>

  <%= render "shared/checklist_form", event: event, item: item %>

  <div class="mt-6 space-y-2">
    <div id="checklist_items" class="space-y-2">
      <%= render partial: "shared/checklist_item", collection: items, as: :item, locals: { event: event } %>
    </div>
    <% if items.empty? %>
      <div id="checklist_empty" class="bg-white rounded-xl ring-1 ring-gray-200 text-center py-12 text-gray-500 text-sm">
        Nenhuma tarefa ainda. Adicione a primeira acima.
      </div>
    <% end %>
  </div>
</div>
