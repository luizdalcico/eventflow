<%#
  Linha editável de convidado.
  Desktop: célula de planilha (Excel), tudo visível.
  Mobile: card colapsável — mostra só o nome; toca pra abrir e editar.
  Locals: `guest`, `event`.
%>
<%# No load inicial tudo começa colapsado; só a linha recém-adicionada vem aberta. %>
<% collapsed = !local_assigns.fetch(:expanded, false) %>
<%
  detail = "#{collapsed ? 'hidden' : 'block'} md:table-cell align-middle border-b border-gray-100 " \
           "last:border-b-0 md:border md:border-gray-200"
  field  = "w-full bg-transparent px-2 py-1.5 text-sm text-gray-800 placeholder-gray-400 " \
           "border-0 focus:bg-blue-50 focus:outline-none"
  label  = "md:hidden block text-[11px] font-medium text-gray-500 px-2 pt-1.5"
  act    = { action: "input->guest-row#save change->guest-row#save" }
  rsvp_badge = { "confirmed" => "✅", "declined" => "❌", "sent" => "⏳" }[guest.rsvp_status]
%>

<tr id="guest_<%= guest.id %>"
    data-controller="guest-row pair-collapse"
    data-guest-row-url-value="<%= event_guest_path(event, guest) %>"
    data-pair-collapse-append-target-value="guests_body"
    class="block md:table-row bg-white border border-gray-300 md:border-0 rounded-lg md:rounded-none mb-4 md:mb-0">

  <%# Resumo (só mobile) — clique pra abrir/fechar %>
  <td class="md:hidden block px-3 py-3 cursor-pointer select-none" data-action="click->pair-collapse#toggle">
    <div class="flex items-center justify-between gap-2">
      <div class="flex items-baseline gap-2 min-w-0">
        <span class="text-sm font-medium text-gray-800 truncate"><%= guest.name.presence || "—" %></span>
        <span class="shrink-0 text-xs text-gray-400"><%= pluralize(guest.party_size, "pessoa", "pessoas") %></span>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <% if rsvp_badge %><span class="text-xs"><%= rsvp_badge %></span><% end %>
        <span data-pair-collapse-target="chevron"
              class="text-gray-400 transition-transform <%= "rotate-180" unless collapsed %>">▾</span>
      </div>
    </div>
  </td>

  <%# Seleção para envio %>
  <td class="<%= detail %> md:w-8 md:text-center" data-pair-collapse-target="detail">
    <span class="<%= label %>">Selecionar</span>
    <% if guest.rsvp_invitable? %>
      <%= check_box_tag "guest_ids[]", guest.id, false, data: { "select-all-target": "item" } %>
    <% end %>
  </td>

  <%# Nome %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Nome</span>
    <%= text_field_tag "guest[name]", guest.name, placeholder: "Nome do convidado", class: "#{field} font-medium", data: act %>
  </td>

  <%# Pessoas %>
  <td class="<%= detail %> md:w-20" data-pair-collapse-target="detail">
    <span class="<%= label %>">Pessoas</span>
    <%= number_field_tag "guest[party_size]", guest.party_size, min: 1, class: field, data: act %>
  </td>

  <%# Telefone %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Telefone</span>
    <%= text_field_tag "guest[phone_number]", guest.phone_number, placeholder: "(00) 00000-0000",
          class: field, data: act.merge(controller: "simple-mask", simple_mask_pattern_value: "(00) 00000-0000") %>
  </td>

  <%# RSVP (marcação manual) %>
  <td class="<%= detail %> md:w-44" data-pair-collapse-target="detail">
    <span class="<%= label %>">RSVP</span>
    <%= select_tag "guest[rsvp_status]",
          options_for_select([["— Pendente", "pending"], ["⏳ Enviado", "sent"], ["✅ Confirmado", "confirmed"], ["❌ Recusou", "declined"]], guest.rsvp_status),
          class: field, data: act %>
  </td>

  <%# Observações %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Observações</span>
    <%= text_field_tag "guest[notes]", guest.notes, placeholder: "—", class: field, data: act %>
  </td>

  <%# Remover %>
  <td class="<%= detail %> md:w-8 md:text-center" data-pair-collapse-target="detail">
    <%= link_to event_guest_path(event, guest),
          data: { turbo_method: :delete, turbo_confirm: "Remover este convidado?" }, title: "Remover",
          class: "inline-block px-2 py-1.5 md:p-0 text-gray-400 hover:text-red-600 text-sm" do %>
      <span class="md:hidden">× Remover</span>
      <span class="hidden md:inline text-lg leading-none">×</span>
    <% end %>
  </td>
</tr>
