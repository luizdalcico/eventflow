<% content_for :title, "Convidados - #{@event.title}" %>

<%= breadcrumbs ["Eventos", events_path], [event_crumb_label(@event), @event], ["Convidados", nil] %>

<div class="flex justify-between items-start mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Convidados</h1>
    <p class="text-gray-500"><%= @event.title %></p>
  </div>
  <div class="flex items-center gap-4">
    <%= link_to "🖨 Imprimir", print_event_guests_path(@event), class: "text-blue-600 hover:text-blue-800 text-sm" %>
    <%= link_to "⬇ Exportar", export_event_guests_path(@event), class: "text-blue-600 hover:text-blue-800 text-sm" %>
    <%= link_to "Voltar ao evento", event_path(@event), class: "text-blue-600 hover:text-blue-800 text-sm" %>
  </div>
</div>

<% if @event.wedding? %>
  <div data-controller="tabs">
    <%# Navegação das abas %>
    <% tab_base = "px-4 py-2 -mb-px border-b-2 text-sm font-medium cursor-pointer focus:outline-none" %>
    <div class="flex gap-2 border-b border-gray-200 mb-6">
      <button type="button" data-testid="tab-convidados" data-tabs-target="tab" data-tabs-name="convidados"
              data-action="tabs#select" class="<%= tab_base %>">Convidados</button>
      <button type="button" data-testid="tab-padrinhos" data-tabs-target="tab" data-tabs-name="padrinhos"
              data-action="tabs#select" class="<%= tab_base %>">Padrinhos</button>
      <button type="button" data-testid="tab-familiares" data-tabs-target="tab" data-tabs-name="familiares"
              data-action="tabs#select" class="<%= tab_base %>">Familiares</button>
    </div>

    <div data-tabs-target="panel" data-tabs-name="convidados">
      <%= render "general_tab", event: @event, guests: @guests %>
    </div>
    <div data-tabs-target="panel" data-tabs-name="padrinhos" class="hidden">
      <%= render "padrinhos_tab", event: @event, anchors: @anchors %>
    </div>
    <div data-tabs-target="panel" data-tabs-name="familiares" class="hidden">
      <%= render "familiares_tab", event: @event, family_members: @family_members, family_member: @family_member %>
    </div>
  </div>
<% else %>
  <%= render "general_tab", event: @event, guests: @guests %>
<% end %>
