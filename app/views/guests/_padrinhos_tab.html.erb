<%# Aba "Padrinhos": link público + a mesma tabela editável da página pública. Locals: event, anchors. %>
<% list = @godparent_list %>

<%# Link público para os noivos preencherem %>
<div class="mb-4">
  <%= render "events/godparent_list" %>
</div>

<%# Mesma tabela editável da página pública (o cerimonial pode preencher junto) %>
<%= render "godparents/pairs_table", list: list, anchors: anchors %>

<% if list.editable? %>
  <div class="static md:sticky md:bottom-0 bg-gray-50/90 backdrop-blur border-t border-gray-200 py-4 mt-6 flex flex-wrap gap-3 justify-end items-center">
    <span class="text-sm text-gray-400 mr-auto">As alterações são salvas automaticamente.</span>
    <%= button_to "Finalizar e avisar o cerimonial",
          finalize_godparent_list_path(list.token), method: :patch,
          form: { data: { turbo_confirm: "Tem certeza? Após finalizar não será mais possível editar a lista." } },
          class: "px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700" %>
  </div>
<% end %>
