<%# Aba "Convidados": resumo RSVP, importação e tabela editável. Locals: event, guests. %>

<%# Resumo RSVP %>
<% confirmed = guests.count { |g| g.rsvp_status == "confirmed" } %>
<% declined  = guests.count { |g| g.rsvp_status == "declined" } %>
<% pending   = guests.size - confirmed - declined %>
<% people_total = guests.sum(&:party_size) %>
<% people_confirmed = guests.select { |g| g.rsvp_status == "confirmed" }.sum(&:party_size) %>
<% people_adults = guests.select { |g| g.guest_type == "adult" }.sum(&:party_size) %>
<% people_children = guests.select { |g| g.guest_type == "child" }.sum(&:party_size) %>
<div class="grid grid-cols-3 gap-4 mb-2">
  <div class="bg-green-50 border border-green-200 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-green-700"><%= confirmed %></div>
    <div class="text-sm text-green-700">Confirmados</div>
  </div>
  <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-red-700"><%= declined %></div>
    <div class="text-sm text-red-700">Recusaram</div>
  </div>
  <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center">
    <div class="text-2xl font-bold text-gray-700"><%= pending %></div>
    <div class="text-sm text-gray-600">Pendentes</div>
  </div>
</div>
<p class="text-sm text-gray-500 mb-6 text-center">
  <strong><%= people_total %></strong> pessoas no total · <strong class="text-green-700"><%= people_confirmed %></strong> confirmadas<br>
  <strong><%= people_adults %></strong> adultos · <strong><%= people_children %></strong> crianças
</p>

<%# Importar do Excel %>
<div class="bg-white rounded-lg shadow p-4 mb-6">
  <div class="flex items-center justify-between mb-2">
    <h2 class="text-lg font-semibold text-gray-900">Importar convidados</h2>
    <%= link_to "⬇ Baixar modelo", template_event_guests_path(event), class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>
  <p class="text-sm text-gray-500 mb-3">
    Envie um <strong>.xlsx</strong> ou <strong>.csv</strong> com colunas <strong>Nome</strong>, <strong>Quantidade</strong>, <strong>Telefone</strong> e (opcional) <strong>Observações</strong>.
    Se houver coluna de confirmação (SIM/NÃO), o RSVP já vem preenchido.
  </p>
  <%= form_with url: import_event_guests_path(event), method: :post, multipart: true,
        data: { controller: "file-input" }, class: "flex flex-wrap items-center gap-3" do %>
    <%= file_field_tag :file, accept: ".xlsx,.csv", id: "guest_import_file", class: "hidden",
          data: { file_input_target: "input", action: "change->file-input#display" } %>
    <label for="guest_import_file"
           class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 border border-gray-400 text-gray-700 rounded-lg hover:bg-gray-200 cursor-pointer text-sm font-medium">
      📎 Escolher arquivo
    </label>
    <span data-file-input-target="name" class="text-sm text-gray-500">Nenhum arquivo selecionado</span>
    <%= submit_tag "Importar", class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 cursor-pointer text-sm" %>
  <% end %>
</div>

<%# Tabela editável + envio de RSVP %>
<%= form_with url: send_rsvp_event_guests_path(event), method: :post, data: { controller: "select-all" } do %>
  <div class="overflow-x-auto bg-white rounded-xl ring-1 ring-gray-200 shadow-sm">
    <table class="block md:table w-full border-collapse text-sm">
      <thead class="hidden md:table-header-group bg-gray-100">
        <tr>
          <th class="border border-gray-200 px-2 py-2 w-8 text-center">
            <%= check_box_tag "all", "1", false, data: { action: "select-all#toggle" } %>
          </th>
          <th class="border border-gray-200 px-2 py-2 text-left text-xs font-semibold text-gray-600">Nome</th>
          <th class="border border-gray-200 px-2 py-2 text-left text-xs font-semibold text-gray-600">Pessoas</th>
          <th class="border border-gray-200 px-2 py-2 text-left text-xs font-semibold text-gray-600">Tipo</th>
          <th class="border border-gray-200 px-2 py-2 text-left text-xs font-semibold text-gray-600">Telefone</th>
          <th class="border border-gray-200 px-2 py-2 text-left text-xs font-semibold text-gray-600">RSVP</th>
          <th class="border border-gray-200 px-2 py-2 text-left text-xs font-semibold text-gray-600">Observações</th>
          <th class="border border-gray-200 w-8"></th>
        </tr>
      </thead>
      <tbody id="guests_body" class="block md:table-row-group p-3 md:p-0">
        <%= render partial: "guest_row", collection: guests, as: :guest, locals: { event: event } %>
      </tbody>
    </table>

    <%= link_to event_guests_path(event), data: { turbo_method: :post },
          class: "flex items-center gap-2 w-full px-4 py-3 text-sm font-medium text-gray-500 hover:text-blue-600 hover:bg-gray-50 border-t border-gray-200" do %>
      <span class="text-lg leading-none">＋</span> Adicionar convidado
    <% end %>
  </div>

  <div class="sticky bottom-0 bg-gray-50/90 backdrop-blur border-t border-gray-200 py-4 mt-6 flex flex-col md:flex-row md:flex-wrap gap-3 md:justify-end md:items-center">
    <span class="text-sm text-gray-400 md:mr-auto">Edição salva automaticamente.</span>
    <%= submit_tag "📨 Enviar RSVP para os convidados selecionados",
          class: "px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 cursor-pointer text-sm" %>
    <%= button_tag "📨 Enviar RSVP para TODOS os convidados",
          type: :submit, name: "all", value: "1",
          data: { turbo_confirm: "Enviar o convite RSVP para TODOS os convidados com telefone?", confirm_label: "Enviar" },
          class: "px-4 py-2 bg-green-700 text-white rounded-lg hover:bg-green-800 cursor-pointer text-sm" %>
  </div>
<% end %>
