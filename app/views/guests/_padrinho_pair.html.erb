<%#
  Linha somente-leitura de um par de padrinhos (madrinha + padrinho).
  Locals: madrinha (Godparent âncora).
%>
<% padrinho = madrinha.pair %>
<% side_labels = { "noiva" => "Noiva", "noivo" => "Noivo", "sem_lado" => "Sem lado" } %>
<% relation_labels = { "irmao" => "Irmã(o)", "amigo" => "Amigo(a)", "avo" => "Avô(ó)", "primo" => "Primo(a)", "outro" => "Outro" } %>

<tr class="border-t border-gray-100">
  <td class="px-3 py-2.5 text-center text-gray-400 font-semibold"><%= madrinha.position %></td>
  <td class="px-3 py-2.5 text-gray-600"><%= side_labels[madrinha.side] || "—" %></td>
  <td class="px-3 py-2.5">
    <div class="font-medium text-gray-800"><%= madrinha.name.presence || "—" %></div>
    <div class="text-xs text-gray-400">
      <%= format_phone(madrinha.phone_number) if madrinha.phone_number.present? %>
      <%= "· #{relation_labels[madrinha.relation]}" if madrinha.relation.present? %>
    </div>
  </td>
  <td class="px-3 py-2.5">
    <div class="font-medium text-gray-800"><%= padrinho&.name.presence || "—" %></div>
    <div class="text-xs text-gray-400">
      <%= format_phone(padrinho.phone_number) if padrinho&.phone_number.present? %>
      <%= "· #{relation_labels[padrinho.relation]}" if padrinho&.relation.present? %>
    </div>
  </td>
  <td class="px-3 py-2.5 text-gray-600">
    <%= t("godparent.relationships.#{madrinha.relationship}", default: "—") if madrinha.relationship.present? %>
  </td>
</tr>
