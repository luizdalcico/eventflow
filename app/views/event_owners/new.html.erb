<% content_for :title, "Novo Responsável - Cerimonial.app" %>

<%= breadcrumbs ["Eventos", events_path], [event_crumb_label(@event), @event], ["Responsáveis", event_event_owners_path(@event)], ["Novo", nil] %>

<div class="mb-6">
  <h1 class="text-3xl font-bold text-gray-900">Novo Responsável</h1>
  <p class="text-gray-600 mt-2">
    Adicionar responsável ao evento: <%= @event.title || translate_event_type(@event.event_type) %>
  </p>
</div>

<div class="bg-white rounded-lg shadow-lg p-6">
  <%= render "form", submit_label: "Criar Responsável", cancel_path: event_event_owners_path(@event) %>
</div>
