<%= form_with model: [@event, @event_owner], local: true, class: "space-y-6",
    data: { controller: "cpf-lookup", "cpf-lookup-url-value": lookup_event_event_owners_path(@event) } do |form| %>
  <% if @event_owner.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-red-800 mb-2">
        <%= pluralize(@event_owner.errors.count, "erro") %> encontrado<%= "s" if @event_owner.errors.count > 1 %>:
      </h3>
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% @event_owner.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <%= form.label :name, "Nome Completo", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :name,
          data: { "cpf-lookup-target": "field", "cpf-lookup-field": "name" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.email_field :email,
          data: { "cpf-lookup-target": "field", "cpf-lookup-field": "email" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <%= form.label :phone_number, "Telefone", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :phone_number,
          placeholder: "(11) 99999-9999",
          data: { controller: "simple-mask", "simple-mask-pattern-value": "(00) 00000-0000",
                  "cpf-lookup-target": "field", "cpf-lookup-field": "phone_number" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :cpf, "CPF", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :cpf,
          placeholder: "000.000.000-00",
          data: { controller: "simple-mask", "simple-mask-pattern-value": "000.000.000-00",
                  "cpf-lookup-target": "cpf", action: "input->cpf-lookup#lookup blur->cpf-lookup#lookup" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div>
    <%= form.label :address, "Endereço", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :address, placeholder: "Rua, número, bairro, cidade",
        data: { "cpf-lookup-target": "field", "cpf-lookup-field": "address" },
        class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <%= form.label :mother_name, "Nome da Mãe", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :mother_name,
          data: { "cpf-lookup-target": "field", "cpf-lookup-field": "mother_name" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :father_name, "Nome do Pai", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :father_name,
          data: { "cpf-lookup-target": "field", "cpf-lookup-field": "father_name" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <%= form.label :birth_date, "Data de Aniversário", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.date_field :birth_date,
          data: { "cpf-lookup-target": "field", "cpf-lookup-field": "birth_date" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :instagram, "Instagram", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :instagram, placeholder: "@usuario",
          data: { "cpf-lookup-target": "field", "cpf-lookup-field": "instagram" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  </div>

  <div>
    <%= form.label :role, "Função no Evento", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :role, placeholder: "ex: Noiva, Aniversariante, Responsável", class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <!-- Form Actions -->
  <div class="flex justify-between pt-6 border-t">
    <%= link_to "Cancelar", cancel_path, class: "bg-gray-300 hover:bg-gray-400 text-gray-700 font-medium py-2 px-4 rounded-lg" %>
    <%= form.submit submit_label, class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg" %>
  </div>
<% end %>
