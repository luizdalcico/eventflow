<% content_for :title, "#{@event_owner.name} - Cerimonial.app" %>

<div class="mb-6">
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @event_owner.name %></h1>
      <p class="text-gray-600 mt-2">
        Responsável pelo evento: <%= @event.title || translate_event_type(@event.event_type) %>
      </p>
    </div>
    <div class="flex space-x-2">
      <%= link_to "Editar", edit_event_event_owner_path(@event, @event_owner), class: "bg-yellow-600 hover:bg-yellow-700 text-white font-medium py-2 px-4 rounded-lg" %>
      <%= link_to "Excluir", [@event, @event_owner], method: :delete, 
          confirm: "Tem certeza que deseja excluir este responsável?",
          class: "bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg" %>
    </div>
  </div>
</div>

<div class="bg-white rounded-lg shadow-lg p-6">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Informações do Responsável</h2>
  
  <div class="grid md:grid-cols-2 gap-6">
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">Nome Completo</label>
        <p class="mt-1 text-sm text-gray-900"><%= @event_owner.name %></p>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700">Email</label>
        <p class="mt-1 text-sm text-gray-900">
          <% if @event_owner.email.present? %>
            <a href="mailto:<%= @event_owner.email %>" class="text-blue-600 hover:text-blue-800">
              <%= @event_owner.email %>
            </a>
          <% else %>
            <span class="text-gray-500">Não informado</span>
          <% end %>
        </p>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700">Telefone</label>
        <p class="mt-1 text-sm text-gray-900">
          <% if @event_owner.phone_number.present? %>
            <span class="inline-flex items-center gap-1.5">
              <a href="tel:<%= @event_owner.phone_number %>" class="text-blue-600 hover:text-blue-800">
                <%= @event_owner.phone_number %>
              </a>
              <%= whatsapp_link(@event_owner.phone_number) %>
            </span>
          <% else %>
            <span class="text-gray-500">Não informado</span>
          <% end %>
        </p>
      </div>
    </div>
    
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700">CPF</label>
        <p class="mt-1 text-sm text-gray-900">
          <%= @event_owner.cpf.present? ? @event_owner.cpf : "Não informado" %>
        </p>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700">Função no Evento</label>
        <p class="mt-1 text-sm text-gray-900">
          <%= @event_owner.role.present? ? @event_owner.role : "Não definida" %>
        </p>
      </div>
      
      <div>
        <label class="block text-sm font-medium text-gray-700">Cadastrado em</label>
        <p class="mt-1 text-sm text-gray-900">
          <%= @event_owner.created_at.strftime('%d/%m/%Y às %H:%M') %>
        </p>
      </div>
    </div>
  </div>
</div>

<!-- Event Information -->
<div class="mt-6 bg-white rounded-lg shadow-lg p-6">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Evento Associado</h2>
  
  <div class="border border-gray-200 rounded-lg p-4">
    <div class="flex justify-between items-start">
      <div>
        <h3 class="font-medium text-gray-900">
          <%= link_to (@event.title || translate_event_type(@event.event_type)), @event, class: "text-blue-600 hover:text-blue-800" %>
        </h3>
        <p class="text-sm text-gray-600 mt-1">
          <%= @event.main_date.strftime('%d/%m/%Y') %>
          <% if @event.place.present? %>
            • <%= @event.place %>
          <% end %>
        </p>
        <% if @event.estimated_guests.present? %>
          <p class="text-sm text-gray-500 mt-1">
            <%= pluralize(@event.estimated_guests, 'convidado') %>
          </p>
        <% end %>
      </div>
      <div class="text-right">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
          <%= translate_event_type(@event.event_type) %>
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Back Navigation -->
<div class="mt-6 flex justify-between">
  <%= link_to "← Voltar para Responsáveis", event_event_owners_path(@event), class: "text-blue-600 hover:text-blue-800 font-medium" %>
  <%= link_to "Ver Evento", @event, class: "text-blue-600 hover:text-blue-800 font-medium" %>
</div>