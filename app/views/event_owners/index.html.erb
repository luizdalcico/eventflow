<% content_for :title, "Responsáveis - #{@event.title || translate_event_type(@event.event_type)} - Cerimonial.app" %>

<%= breadcrumbs ["Eventos", events_path], [event_crumb_label(@event), @event], ["Responsáveis", nil] %>

<div class="mb-6">
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Responsáveis pelo Evento</h1>
      <p class="text-gray-600 mt-2"><%= @event.title || translate_event_type(@event.event_type) %> - <%= @event.main_date.strftime('%d/%m/%Y') %></p>
    </div>
    <%= link_to "Novo Responsável", new_event_event_owner_path(@event), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
  </div>
</div>

<% if @event_owners.any? %>
  <div class="bg-white rounded-lg shadow overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Telefone</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">CPF</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Instagram</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Função</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @event_owners.each do |event_owner| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="text-sm font-medium text-gray-900"><%= event_owner.name %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if event_owner.email.present? %>
                  <a href="mailto:<%= event_owner.email %>" class="text-blue-600 hover:text-blue-800">
                    <%= event_owner.email %>
                  </a>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if event_owner.phone_number.present? %>
                  <span class="inline-flex items-center gap-1.5">
                    <a href="tel:<%= event_owner.phone_number %>" class="text-blue-600 hover:text-blue-800">
                      <%= event_owner.phone_number %>
                    </a>
                    <%= whatsapp_link(event_owner.phone_number) %>
                  </span>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= event_owner.cpf.present? ? event_owner.cpf : "-" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <% if event_owner.instagram.present? %>
                  <a href="https://instagram.com/<%= event_owner.instagram %>" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-800">
                    @<%= event_owner.instagram %>
                  </a>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                <%= event_owner.role.present? ? event_owner.role : "-" %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-2">
                <%= link_to "Ver", [@event, event_owner], class: "text-blue-600 hover:text-blue-900" %>
                <%= link_to "Editar", edit_event_event_owner_path(@event, event_owner), class: "text-yellow-600 hover:text-yellow-900" %>
                <%= link_to "Excluir", [@event, event_owner], method: :delete, 
                    confirm: "Tem certeza que deseja excluir este responsável?",
                    class: "text-red-600 hover:text-red-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="text-center py-12">
    <div class="text-gray-500 text-lg mb-4">Nenhum responsável cadastrado ainda</div>
    <%= link_to "Cadastrar Primeiro Responsável", new_event_event_owner_path(@event), class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
  </div>
<% end %>

<div class="mt-6">
  <%= link_to "← Voltar para Evento", @event, class: "text-blue-600 hover:text-blue-800 font-medium" %>
</div>