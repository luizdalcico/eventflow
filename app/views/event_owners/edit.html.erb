<% content_for :title, "Editar Responsável - Cerimonial.app" %>

<div class="mb-6">
  <h1 class="text-3xl font-bold text-gray-900">Editar Responsável</h1>
  <p class="text-gray-600 mt-2">
    Atualizar informações de <%= @event_owner.name %> - <%= @event.title || translate_event_type(@event.event_type) %>
  </p>
</div>

<div class="bg-white rounded-lg shadow-lg p-6">
  <%= form_with model: [@event, @event_owner], local: true, class: "space-y-6" do |form| %>
    <% if @event_owner.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h3 class="text-sm font-medium text-red-800 mb-2">
          <%= pluralize(@event_owner.errors.count, "erro") %> encontrado<%= "s" if @event_owner.errors.count > 1 %>:
        </h3>
        <ul class="text-sm text-red-700 list-disc list-inside">
          <% @event_owner.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <%= form.label :name, "Nome Completo", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.label :email, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.email_field :email, class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <%= form.label :phone_number, "Telefone", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :phone_number, 
            placeholder: "(11) 99999-9999", 
            data: { controller: "simple-mask", "simple-mask-pattern-value": "(00) 00000-0000" },
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.label :cpf, "CPF", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :cpf, 
            placeholder: "000.000.000-00", 
            data: { controller: "simple-mask", "simple-mask-pattern-value": "000.000.000-00" },
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
      </div>
    </div>

    <div>
      <%= form.label :role, "Função no Evento", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :role, placeholder: "ex: Noiva, Aniversariante, Responsável", class: "w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <!-- Form Actions -->
    <div class="flex justify-between pt-6 border-t">
      <%= link_to "Cancelar", [@event, @event_owner], class: "bg-gray-300 hover:bg-gray-400 text-gray-700 font-medium py-2 px-4 rounded-lg" %>
      <%= form.submit "Atualizar Responsável", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-lg" %>
    </div>
  <% end %>
</div>

