<% content_for :title, "Editar Responsável - Cerimonial.app" %>

<div class="mb-6">
  <h1 class="text-3xl font-bold text-gray-900">Editar Responsável</h1>
  <p class="text-gray-600 mt-2">
    Atualizar informações de <%= @event_owner.name %> - <%= @event.title || translate_event_type(@event.event_type) %>
  </p>
</div>

<div class="bg-white rounded-lg shadow-lg p-6">
  <%= render "form", submit_label: "Atualizar Responsável", cancel_path: [@event, @event_owner] %>
</div>
