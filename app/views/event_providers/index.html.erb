<% content_for :title, "Fornecedores do evento - Cerimonial.app" %>

<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Voltar ao evento", @event, class: "text-sm text-blue-600 hover:text-blue-800" %>
    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mt-1">Fornecedores do evento</h1>
    <p class="text-gray-500 mt-1">Associe fornecedores já cadastrados a este evento</p>
  </div>

  <%= render "event_providers/add_form", event: @event, available_providers: @available_providers %>

  <div class="mt-6">
    <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Tipo</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Fornecedor</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Contato</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Valor contratado</th>
            <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Observações</th>
            <th scope="col" class="px-4 py-3 text-right font-semibold text-gray-500 uppercase tracking-wide text-xs">Ações</th>
          </tr>
        </thead>
        <tbody id="event_providers" class="divide-y divide-gray-100">
          <%= render partial: "event_providers/event_provider", collection: @event_providers, as: :event_provider, locals: { event: @event } %>
        </tbody>
      </table>
    </div>
    <% if @event_providers.empty? %>
      <div id="event_providers_empty" class="bg-white rounded-xl ring-1 ring-gray-200 text-center py-12 text-gray-500 text-sm mt-3">
        Nenhum fornecedor associado a este evento ainda.
      </div>
    <% end %>
  </div>
</div>
