<%# Fornecedor contratado para o evento. Locals: event, event_provider. %>
<% p = event_provider.provider %>
<div id="<%= dom_id(event_provider) %>" class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <%= link_to p.name, provider_path(p), class: "font-semibold text-gray-900 hover:text-blue-600" %>
      <div class="text-sm text-gray-500 mt-0.5 flex flex-wrap gap-x-2">
        <span class="inline-flex px-2 py-0.5 text-xs font-semibold rounded-full bg-blue-100 text-blue-800"><%= translate_provider_type(p.provider_type) %></span>
        <% if p.contact_name.present? %><span>👤 <%= p.contact_name %></span><% end %>
        <% if p.phone_number.present? %><span>📞 <%= format_phone(p.phone_number) %></span><% end %>
      </div>
    </div>
    <%= link_to "×", [event, event_provider], title: "Remover do evento",
          data: { turbo_method: :delete, turbo_confirm: "Remover #{p.name} deste evento?", confirm_label: "Remover" },
          class: "shrink-0 text-gray-400 hover:text-red-600 text-lg leading-none px-1" %>
  </div>

  <%= form_with url: update_details_event_event_provider_path(event, event_provider), method: :patch,
        data: { controller: "autosave" }, class: "mt-3 grid sm:grid-cols-2 gap-3" do %>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Valor contratado</label>
      <%= text_field_tag "event_provider[value]", event_provider.custom_detail(:value), placeholder: "R$ 0,00",
            data: { action: "input->autosave#save" },
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Observações</label>
      <%= text_field_tag "event_provider[notes]", event_provider.custom_detail(:notes), placeholder: "—",
            data: { action: "input->autosave#save" },
            class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
    </div>
  <% end %>
</div>
