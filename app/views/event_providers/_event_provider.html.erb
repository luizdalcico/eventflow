<%# Provider contracted for the event (table row). Locals: event, event_provider. %>
<% p = event_provider.provider %>
<% form_id = "ep_form_#{event_provider.id}" %>
<tr id="<%= dom_id(event_provider) %>" class="hover:bg-gray-50 align-top" data-controller="autosave">
  <td class="px-4 py-3 whitespace-nowrap">
    <span class="inline-flex px-2 py-0.5 text-xs font-semibold rounded-full bg-blue-100 text-blue-800"><%= translate_provider_type(p.provider_type) %></span>
  </td>
  <td class="px-4 py-3">
    <%= link_to p.name, provider_path(p), class: "font-semibold text-gray-900 hover:text-blue-600" %>
    <%# Auto-save form linked to the value/notes cells via the HTML `form` attribute. %>
    <%= form_with url: update_details_event_event_provider_path(event, event_provider), method: :patch,
          id: form_id do %>
    <% end %>
  </td>
  <td class="px-4 py-3 text-gray-600">
    <% if p.contact_name.present? %><div>👤 <%= p.contact_name %></div><% end %>
    <% if p.phone_number.present? %><div class="flex items-center gap-1">📞 <%= format_phone(p.phone_number) %> <%= whatsapp_link(p.phone_number) %></div><% end %>
  </td>
  <td class="px-4 py-3">
    <%= select_tag "event_provider[status]",
          options_for_select(EventProvider::STATUSES.map { |s| [translate_provider_status(s), s] }, event_provider.status),
          form: form_id, data: { action: "change->autosave#save" },
          class: "border border-gray-300 rounded-lg px-2 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </td>
  <td class="px-4 py-3">
    <%= number_field_tag "event_provider[professionals_count]", event_provider.professionals_count, min: 0, placeholder: "—",
          form: form_id, data: { action: "input->autosave#save" },
          class: "w-20 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </td>
  <td class="px-4 py-3">
    <%= text_field_tag "event_provider[value]", event_provider.value.present? ? format_brl(event_provider.value) : nil, placeholder: "R$ 0,00",
          form: form_id, data: { action: "input->autosave#save" },
          class: "w-32 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </td>
  <td class="px-4 py-3">
    <%= text_field_tag "event_provider[paid_value]", event_provider.paid_value.present? ? format_brl(event_provider.paid_value) : nil, placeholder: "R$ 0,00",
          form: form_id, data: { action: "input->autosave#save" },
          class: "w-32 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </td>
  <td class="px-4 py-3">
    <%= text_field_tag "event_provider[notes]", event_provider.custom_detail(:notes), placeholder: "—",
          form: form_id, data: { action: "input->autosave#save" },
          class: "w-full min-w-[10rem] border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </td>
  <td class="px-4 py-3 whitespace-nowrap text-right">
    <%= link_to "×", [event, event_provider], title: "Remover do evento",
          data: { turbo_method: :delete, turbo_confirm: "Remover #{p.name} deste evento?", confirm_label: "Remover" },
          class: "text-gray-400 hover:text-red-600 text-lg leading-none px-1" %>
  </td>
</tr>
