<%# Cost-sheet totals for the event. Locals: event. %>
<div id="providers_totals" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-4">
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Custo total</div>
    <div class="text-lg font-bold text-gray-900 mt-1"><%= format_brl(event.providers_total_cost) %></div>
  </div>
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Total pago</div>
    <div class="text-lg font-bold text-green-700 mt-1"><%= format_brl(event.providers_paid_total) %></div>
  </div>
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Saldo a pagar</div>
    <div class="text-lg font-bold text-red-700 mt-1"><%= format_brl(event.providers_balance) %></div>
  </div>
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Profissionais</div>
    <div class="text-lg font-bold text-gray-900 mt-1"><%= event.providers_total_professionals %></div>
  </div>
</div>
