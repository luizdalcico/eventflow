<%# Automatic balance summary for the event. Locals: event. %>
<div id="payments_totals" class="grid grid-cols-1 sm:grid-cols-3 gap-3">
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Valor do contrato</div>
    <div class="text-lg font-bold text-gray-900 mt-1"><%= format_brl(event.contract_total_value || 0) %></div>
  </div>
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Total recebido</div>
    <div class="text-lg font-bold text-green-700 mt-1"><%= format_brl(event.payments_total) %></div>
  </div>
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4">
    <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Restando</div>
    <div class="text-lg font-bold text-red-700 mt-1"><%= format_brl(event.payments_balance) %></div>
  </div>
</div>
