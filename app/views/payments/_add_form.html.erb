<%# Form to register a new payment. Locals: event, payment. %>
<% field = "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
<div id="add_payment">
  <%= form_with model: payment, url: event_payments_path(event), method: :post,
        class: "bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4" do |f| %>
    <% if payment.errors.any? %>
      <div class="mb-3 rounded-lg bg-red-50 text-red-700 text-sm px-3 py-2">
        <%= payment.errors.full_messages.to_sentence %>
      </div>
    <% end %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
      <div class="lg:col-span-2">
        <label class="block text-xs font-semibold text-gray-500 mb-1">Recebido de</label>
        <%= f.text_field :payer_name, placeholder: "Nome de quem pagou", class: "w-full #{field}" %>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 mb-1">Valor</label>
        <%= f.text_field :amount, value: (format_brl(payment.amount) if payment.amount.present?), placeholder: "R$ 0,00", class: "w-full #{field}" %>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 mb-1">Forma</label>
        <%= f.select :payment_method,
              options_for_select(Payment::PAYMENT_METHODS.map { |m| [translate_payment_method(m), m] }, payment.payment_method),
              {}, class: "w-full #{field}" %>
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 mb-1">Data</label>
        <%= f.date_field :paid_on, class: "w-full #{field}" %>
      </div>
      <div class="lg:col-span-4">
        <label class="block text-xs font-semibold text-gray-500 mb-1">Referente à</label>
        <%= f.text_field :reference, placeholder: "Ex.: entrada, 2ª parcela…", class: "w-full #{field}" %>
      </div>
      <div class="flex items-end">
        <%= f.submit "Registrar pagamento",
              class: "w-full px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm cursor-pointer whitespace-nowrap" %>
      </div>
    </div>
  <% end %>
</div>
