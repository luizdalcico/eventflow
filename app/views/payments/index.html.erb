<% content_for :title, "Pagamentos do evento - Cerimonial.app" %>

<%= breadcrumbs ["Eventos", events_path], [event_crumb_label(@event), @event], ["Pagamentos", nil] %>
<div class="mb-6">
  <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Pagamentos do evento</h1>
  <p class="text-gray-500 mt-1">Registre os pagamentos recebidos e gere o recibo de cada um</p>
</div>

<%= render "payments/totals", event: @event %>

<div class="mt-6">
  <%= render "payments/add_form", event: @event, payment: @payment %>
</div>

<div class="mt-6">
  <div class="bg-white rounded-xl ring-1 ring-gray-200 shadow-sm overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Recebido de</th>
          <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Valor</th>
          <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Referente à</th>
          <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Forma</th>
          <th scope="col" class="px-4 py-3 text-left font-semibold text-gray-500 uppercase tracking-wide text-xs">Data</th>
          <th scope="col" class="px-4 py-3 text-right font-semibold text-gray-500 uppercase tracking-wide text-xs">Ações</th>
        </tr>
      </thead>
      <tbody id="payments" class="divide-y divide-gray-100">
        <%= render partial: "payments/payment", collection: @payments, as: :payment, locals: { event: @event } %>
      </tbody>
    </table>
  </div>
  <% if @payments.empty? %>
    <div id="payments_empty" class="bg-white rounded-xl ring-1 ring-gray-200 text-center py-12 text-gray-500 text-sm mt-3">
      Nenhum pagamento registrado para este evento ainda.
    </div>
  <% end %>
</div>
