<% content_for :title, "#{@provider.name} - Cerimonial.app" %>
<% card = "bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-5 md:p-6" %>

<div class="mb-6">
  <%= link_to "← Fornecedores", providers_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mt-1">
    <div class="min-w-0">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900"><%= @provider.name %></h1>
      <span class="inline-flex mt-2 px-2.5 py-1 text-xs font-semibold rounded-full bg-blue-100 text-blue-800">
        <%= translate_provider_type(@provider.provider_type) %>
      </span>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= link_to "Editar", edit_provider_path(@provider), class: "px-4 py-2 rounded-lg bg-yellow-500 hover:bg-yellow-600 text-white font-medium text-sm" %>
      <%= link_to "Excluir", @provider,
            data: { turbo_method: :delete, turbo_confirm: "Excluir este fornecedor?", confirm_label: "Excluir" },
            class: "px-4 py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white font-medium text-sm" %>
    </div>
  </div>
</div>

<div class="grid lg:grid-cols-2 gap-6">
  <!-- Informações -->
  <div class="<%= card %>">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Informações</h2>
    <dl class="space-y-4 text-sm">
      <div>
        <dt class="text-gray-500">Nome do contato</dt>
        <dd class="text-gray-900 font-medium"><%= @provider.contact_name.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-gray-500">Telefone</dt>
        <dd class="font-medium">
          <% if @provider.phone_number.present? %>
            <span class="inline-flex items-center gap-1.5">
              <a href="tel:<%= @provider.phone_number %>" class="text-blue-600 hover:text-blue-800"><%= format_phone(@provider.phone_number) %></a>
              <%= whatsapp_link(@provider.phone_number) %>
            </span>
          <% else %>
            <span class="text-gray-500">Não informado</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-gray-500">Documento (CNPJ/CPF)</dt>
        <dd class="text-gray-900"><%= @provider.document.presence || "Não informado" %></dd>
      </div>
      <div>
        <dt class="text-gray-500">Cadastrado em</dt>
        <dd class="text-gray-900"><%= @provider.created_at.strftime("%d/%m/%Y às %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <!-- Eventos associados -->
  <div class="<%= card %>">
    <h2 class="text-base font-semibold text-gray-900 mb-4">Eventos associados</h2>
    <% if @provider.events.any? %>
      <div class="space-y-3">
        <% @provider.events.each do |event| %>
          <%= link_to event, class: "block border border-gray-100 rounded-lg p-3 hover:bg-gray-50" do %>
            <div class="font-medium text-gray-900"><%= event.title.presence || translate_event_type(event.event_type) %></div>
            <div class="text-sm text-gray-500 mt-0.5">
              <%= event.main_date.strftime("%d/%m/%Y") if event.main_date %>
              <% if event.place.present? %> · <%= event.place %><% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm">Este fornecedor ainda não está associado a nenhum evento</p>
    <% end %>
  </div>
</div>
