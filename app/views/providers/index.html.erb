<% content_for :title, "Fornecedores - EventFlow" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold text-gray-900">Fornecedores</h1>
  <%= link_to "Novo Fornecedor", new_provider_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
</div>

<% if @providers_by_type.any? %>
  <% @providers_by_type.each do |provider_type, providers| %>
    <div class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-4"><%= translate_provider_type(provider_type) %></h2>
      <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Nome</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Contato</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Telefone</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Documento</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ações</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% providers.each do |provider| %>
                <tr class="hover:bg-gray-50">
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="text-sm font-medium text-gray-900"><%= provider.name %></div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= provider.contact_name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= provider.phone_number %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                    <%= provider.document %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-2">
                    <%= link_to "Ver", provider, class: "text-blue-600 hover:text-blue-900" %>
                    <%= link_to "Editar", edit_provider_path(provider), class: "text-yellow-600 hover:text-yellow-900" %>
                    <%= link_to "Excluir", provider, method: :delete, 
                        confirm: "Tem certeza que deseja excluir este fornecedor?",
                        class: "text-red-600 hover:text-red-900" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-12">
    <div class="text-gray-500 text-lg mb-4">Nenhum fornecedor cadastrado ainda</div>
    <%= link_to "Cadastrar Primeiro Fornecedor", new_provider_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
  </div>
<% end %>
