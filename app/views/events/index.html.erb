<% content_for :title, "Eventos - Cerimonial.app" %>

<%= breadcrumbs ["Eventos", nil] %>

<div class="flex items-center justify-between gap-3 mb-6">
  <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Eventos</h1>
  <%= link_to new_event_path,
        class: "inline-flex items-center gap-1.5 bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-3 md:px-4 rounded-lg text-sm whitespace-nowrap" do %>
    <span class="text-lg leading-none">+</span> <span class="hidden sm:inline">Novo evento</span><span class="sm:hidden">Novo</span>
  <% end %>
</div>

<%# Filtros: busca por nome/responsável + período %>
<%= form_with url: events_path, method: :get, class: "flex flex-col sm:flex-row gap-3 mb-6" do %>
  <div class="relative flex-1">
    <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">🔍</span>
    <%= text_field_tag :q, @query,
          placeholder: "Buscar por evento ou responsável",
          class: "w-full rounded-lg border border-gray-300 pl-9 pr-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500" %>
  </div>
  <%= select_tag :period,
        options_for_select(event_date_filter_options, @period),
        class: "rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500" %>
  <%# Preserve the active card filter when submitting the search/period form. %>
  <%= hidden_field_tag :filter, @filter %>
  <div class="flex gap-2">
    <%= submit_tag "Filtrar",
          class: "bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg text-sm cursor-pointer" %>
    <% if @filters_active %>
      <%= link_to "Limpar", events_path(filter: @filter),
            class: "inline-flex items-center text-gray-600 hover:text-gray-900 text-sm px-2" %>
    <% end %>
  </div>
<% end %>

<%# Resumo compacto — cada card filtra a listagem abaixo, preservando a busca/período %>
<% card_base = "block bg-white rounded-xl ring-1 p-3 md:p-4 text-center transition hover:ring-blue-300" %>
<% card_filters = { q: @query, period: @period } %>
<div class="grid grid-cols-3 gap-3 mb-8">
  <%= link_to events_path(card_filters.merge(filter: "all")),
        class: "#{card_base} #{@filter == 'all' ? 'ring-2 ring-blue-500' : 'ring-gray-200'}" do %>
    <div class="text-2xl font-bold text-blue-600"><%= @total_count %></div>
    <div class="text-xs md:text-sm text-gray-500">Total</div>
  <% end %>
  <%= link_to events_path(card_filters.merge(filter: "upcoming")),
        class: "#{card_base} #{@filter == 'upcoming' ? 'ring-2 ring-green-500' : 'ring-gray-200'}" do %>
    <div class="text-2xl font-bold text-green-600"><%= @upcoming_count %></div>
    <div class="text-xs md:text-sm text-gray-500">Próximos</div>
  <% end %>
  <%= link_to events_path(card_filters.merge(filter: "past")),
        class: "#{card_base} #{@filter == 'past' ? 'ring-2 ring-gray-400' : 'ring-gray-200'}" do %>
    <div class="text-2xl font-bold text-gray-500"><%= @past_count %></div>
    <div class="text-xs md:text-sm text-gray-500">Passados</div>
  <% end %>
</div>

<% if @total_count.zero? && @filters_active %>
  <div class="bg-white rounded-xl ring-1 ring-gray-200 text-center py-16 px-4">
    <div class="text-gray-500 text-lg mb-4">Nenhum evento encontrado para os filtros</div>
    <%= link_to "Limpar filtros", events_path(filter: @filter),
          class: "inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
  </div>
<% elsif @total_count.zero? %>
  <div class="bg-white rounded-xl ring-1 ring-gray-200 text-center py-16 px-4">
    <div class="text-gray-500 text-lg mb-4">Nenhum evento cadastrado ainda</div>
    <%= link_to "Criar primeiro evento", new_event_path,
          class: "inline-block bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg" %>
  </div>
<% else %>
  <% if show_upcoming? && @upcoming_events.any? %>
    <section class="mb-8">
      <h2 class="text-lg font-semibold text-gray-800 mb-3">Próximos eventos</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        <%= render partial: "event_card", collection: @upcoming_events, as: :event %>
      </div>
    </section>
  <% end %>

  <% if show_past? && @past_events.any? %>
    <section>
      <h2 class="text-lg font-semibold text-gray-500 mb-3">Eventos passados</h2>
      <div class="grid gap-4 sm:grid-cols-2 opacity-90">
        <%= render partial: "event_card", collection: @past_events, as: :event %>
      </div>
    </section>
  <% end %>
<% end %>
