<div class="bg-white rounded-lg shadow p-6">
  <h2 class="text-xl font-semibold text-gray-900 mb-4">Lista de Padrinhos</h2>

  <% if @event.godparent_list.present? %>
    <% list = @event.godparent_list %>
    <% url = godparent_list_url(list.token) %>

    <div class="space-y-3" data-controller="clipboard">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Link de preenchimento</label>
        <div class="flex gap-2">
          <input type="text" readonly value="<%= url %>"
                 data-clipboard-target="source"
                 class="flex-1 border border-gray-300 rounded px-3 py-2 text-sm bg-gray-50">
          <button type="button" data-action="clipboard#copy"
                  class="px-3 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm whitespace-nowrap">
            <span data-clipboard-target="label">Copiar</span>
          </button>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <span class="text-gray-500">Status</span>
          <p class="font-medium">
            <% if list.expired? %>
              <span class="text-red-600">Expirado</span>
            <% elsif list.submitted? %>
              <span class="text-green-700">Finalizado<%= " em #{l(list.submitted_at, format: :long)}" if list.submitted_at %></span>
            <% else %>
              <span class="text-yellow-700">Rascunho (aguardando preenchimento)</span>
            <% end %>
          </p>
        </div>
        <div>
          <span class="text-gray-500">Pares preenchidos</span>
          <p class="font-medium"><%= list.pairs_count %></p>
        </div>
        <div>
          <span class="text-gray-500">Expira em</span>
          <p class="font-medium"><%= list.expires_at ? l(list.expires_at, format: :long) : "Sem expiração" %></p>
        </div>
      </div>
    </div>
  <% else %>
    <p class="text-gray-500 text-sm mb-4">
      Gere um link para os noivos preencherem a lista de padrinhos. Você pode definir uma data de expiração.
    </p>
    <%= form_with url: event_godparent_list_path(@event), method: :post, class: "space-y-3" do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Expira em (opcional)</label>
        <%= datetime_field_tag "godparent_list[expires_at]", nil,
              class: "border border-gray-300 rounded px-3 py-2 text-sm" %>
      </div>
      <%= f.submit "Gerar link de preenchimento",
            class: "px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer" %>
    <% end %>
  <% end %>
</div>
