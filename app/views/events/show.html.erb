<% content_for :title, "#{@event.title} - Cerimonial.app" %>
<% upcoming = @event.main_date.present? && @event.main_date >= Date.current %>
<% card = "bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-5 md:p-6" %>

<!-- Header -->
<%= breadcrumbs ["Eventos", events_path], [event_crumb_label(@event), nil] %>
<div class="mb-6">
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div class="min-w-0">
      <h1 class="text-2xl md:text-3xl font-bold text-gray-900"><%= @event.title.presence || "Evento sem título" %></h1>
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-2 text-sm text-gray-600">
        <span class="inline-flex px-2.5 py-1 text-xs font-semibold rounded-full <%= upcoming ? "bg-green-100 text-green-800" : "bg-gray-100 text-gray-600" %>">
          <%= translate_event_type(@event.event_type) %>
        </span>
        <% if @event.main_date %><span>📅 <%= @event.main_date.strftime("%d/%m/%Y") %></span><% end %>
        <% if @event.start_time && @event.end_time %>
          <span>🕐 <%= @event.start_time.strftime("%H:%M") %> – <%= @event.end_time.strftime("%H:%M") %></span>
        <% end %>
        <% if @event_owners.first&.name.present? %><span>· <%= @event_owners.first.name %></span><% end %>
      </div>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= link_to "Editar", edit_event_path(@event), class: "px-4 py-2 rounded-lg bg-yellow-500 hover:bg-yellow-600 text-white font-medium text-sm" %>
      <%= link_to "Exportar PDF", event_path(@event, format: :pdf), class: "px-4 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium text-sm" %>
      <%= link_to "Gerar Contrato", contract_event_path(@event, format: :pdf), class: "px-4 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium text-sm" %>
    </div>
  </div>
</div>

<!-- Cards de resumo (clicáveis) -->
<% summary_card = "block bg-white rounded-xl ring-1 ring-gray-200 hover:ring-blue-300 hover:bg-blue-50/40 p-4 md:p-5 transition" %>
<% cards_grid = @event.wedding? ? "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-6" : "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 mb-6" %>
<div class="<%= cards_grid %>">
  <!-- Card 1 — Convidados -->
  <%= link_to event_guests_path(@event), class: summary_card do %>
    <div class="text-sm font-semibold text-gray-900 mb-3">👥 Convidados</div>
    <dl class="space-y-1.5 text-sm">
      <div class="flex justify-between">
        <dt class="text-gray-500">Convidados</dt>
        <dd class="font-bold text-gray-900"><%= @guests.count %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-gray-500">RSVP confirmados</dt>
        <dd class="font-bold text-green-700"><%= @event.guests.rsvp_confirmed.count %></dd>
      </div>
    </dl>
  <% end %>

  <!-- Card 2 — Fornecedores -->
  <%= link_to event_event_providers_path(@event), class: summary_card do %>
    <div class="text-sm font-semibold text-gray-900 mb-3">🤝 Fornecedores</div>
    <div class="text-2xl font-bold text-gray-900"><%= @providers.count %></div>
    <div class="text-xs text-gray-500 mt-1">cadastrados</div>
  <% end %>

  <!-- Card 3 — Checklist interno -->
  <%= link_to event_manager_checklists_path(@event), class: summary_card do %>
    <div class="text-sm font-semibold text-gray-900 mb-3">✅ Checklist interno</div>
    <div class="text-2xl font-bold text-gray-900"><%= @manager_tasks.pending.count %><span class="text-base font-medium text-gray-400">/<%= @manager_tasks.count %></span></div>
    <div class="text-xs text-gray-500 mt-1">pendentes</div>
  <% end %>

  <!-- Card 4 — Checklist responsáveis -->
  <%= link_to event_owner_checklists_path(@event), class: summary_card do %>
    <div class="text-sm font-semibold text-gray-900 mb-3">📋 Checklist responsáveis</div>
    <div class="text-2xl font-bold text-gray-900"><%= @owner_tasks.pending.count %><span class="text-base font-medium text-gray-400">/<%= @owner_tasks.count %></span></div>
    <div class="text-xs text-gray-500 mt-1">pendentes</div>
  <% end %>

  <!-- Card 5 — Cortejo (só casamento) -->
  <% if @event.wedding? %>
    <%= link_to event_cortejo_path(@event), class: summary_card do %>
      <div class="text-sm font-semibold text-gray-900 mb-3">💍 Cortejo</div>
      <dl class="space-y-1.5 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Momentos</dt>
          <dd class="font-bold text-gray-900"><%= @procession_steps_count %></dd>
        </div>
      </dl>
    <% end %>
  <% end %>
</div>

<div class="grid lg:grid-cols-3 gap-6">
  <!-- Coluna principal -->
  <div class="lg:col-span-2 space-y-6">
    <!-- Informações -->
    <div class="<%= card %>">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Informações do evento</h2>
      <dl class="grid sm:grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="text-gray-500">Local</dt>
          <dd class="text-gray-900 font-medium"><%= @event.place.presence || "Não definido" %></dd>
        </div>
        <div>
          <dt class="text-gray-500">Convidados (estimativa)</dt>
          <dd class="text-gray-900 font-medium"><%= @event.estimated_guests || "—" %></dd>
        </div>
        <% if @event.address.present? %>
          <div class="sm:col-span-2">
            <dt class="text-gray-500">Endereço</dt>
            <dd class="text-gray-900"><%= @event.address %></dd>
          </div>
        <% end %>
        <% if @event.extra_hours.present? && @event.extra_hours > 0 %>
          <div>
            <dt class="text-gray-500">Horas extras</dt>
            <dd class="text-gray-900 font-medium"><%= @event.extra_hours %> h</dd>
          </div>
        <% end %>
      </dl>
    </div>

    <!-- Responsáveis -->
    <div class="<%= card %>">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-base font-semibold text-gray-900">Responsáveis</h2>
        <%= link_to "Gerenciar", event_event_owners_path(@event), class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <% if @event_owners.any? %>
        <div class="space-y-3">
          <% @event_owners.each do |owner| %>
            <div class="border border-gray-100 rounded-lg p-3">
              <div class="font-medium text-gray-900"><%= owner.name %></div>
              <div class="text-sm text-gray-500 flex flex-wrap gap-x-2">
                <% if owner.role.present? %><span><%= owner.role %></span><span>·</span><% end %>
                <span class="inline-flex items-center gap-1"><%= format_phone(owner.phone_number) %> <%= whatsapp_link(owner.phone_number) %></span>
                <% if owner.cpf.present? %><span>·</span><span><%= owner.cpf %></span><% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-sm">Nenhum responsável cadastrado</p>
      <% end %>
    </div>

    <!-- Outras datas -->
    <div class="<%= card %>">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-base font-semibold text-gray-900">Outras datas</h2>
        <%= link_to "Gerenciar", event_event_dates_path(@event), class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>
      <% if @event_dates.any? %>
        <div class="divide-y divide-gray-100">
          <% @event_dates.each do |event_date| %>
            <div class="flex justify-between items-center py-2 text-sm">
              <span class="font-medium text-gray-800"><%= event_date.description %></span>
              <span class="text-gray-500"><%= event_date.date.strftime("%d/%m/%Y") %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-sm">Nenhuma data adicional cadastrada</p>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Próximas tarefas -->
    <% pending_tasks = (@manager_tasks.pending.to_a + @owner_tasks.pending.to_a).sort_by { |t| t.due_date || Date.new(9999) } %>
    <div class="<%= card %>">
      <h3 class="text-base font-semibold text-gray-900 mb-4">Próximas tarefas</h3>
      <% if pending_tasks.any? %>
        <div class="space-y-3">
          <% pending_tasks.first(6).each do |task| %>
            <div class="text-sm">
              <div class="font-medium text-gray-800"><%= task.task %></div>
              <div class="text-gray-500 text-xs flex gap-2">
                <% if task.due_date %><span><%= task.due_date.strftime("%d/%m") %></span><span>·</span><% end %>
                <span><%= task.is_a?(ManagerChecklist) ? "Interno" : "Responsáveis" %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 text-sm">Nenhuma tarefa pendente 🎉</p>
      <% end %>
    </div>
  </div>
</div>
