<%# Painel compacto do link público de familiares. Usa @family_member_list. %>
<% list = @family_member_list %>
<div class="bg-white rounded-lg shadow p-4" data-controller="clipboard">
  <div class="flex items-center justify-between gap-3 mb-2">
    <h2 class="text-sm font-semibold text-gray-900">Link público de familiares</h2>
    <% if list.submitted? %>
      <span class="shrink-0 text-xs font-medium text-green-700">✓ Finalizado<%= " em #{l(list.submitted_at, format: :long)}" if list.submitted_at %></span>
    <% else %>
      <span class="shrink-0 text-xs font-medium text-yellow-700">Aguardando preenchimento</span>
    <% end %>
  </div>
  <div class="flex gap-2">
    <input type="text" readonly value="<%= family_member_list_url(list.token) %>"
           data-clipboard-target="source"
           class="flex-1 min-w-0 border border-gray-300 rounded px-3 py-2 text-sm bg-gray-50">
    <button type="button" data-action="clipboard#copy"
            class="shrink-0 px-3 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 text-sm whitespace-nowrap">
      <span data-clipboard-target="label">Copiar</span>
    </button>
    <%= link_to "Abrir", family_member_list_url(list.token), target: "_blank", rel: "noopener",
          class: "shrink-0 px-3 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 text-sm whitespace-nowrap" %>
  </div>
</div>
