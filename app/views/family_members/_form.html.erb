<%#
  Form de novo familiar — admin + público.
  Locals:
    create_url    — URL de POST
    family_member — instância nova (ou inválida, para re-render com erros)
%>
<%= form_with url: create_url, id: "new_family_member",
      class: "bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4 flex flex-col sm:flex-row gap-3" do %>
  <%= text_field_tag "family_member[name]", family_member.name, placeholder: "Nome", required: true,
        class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  <%= select_tag "family_member[role]",
        options_for_select(FamilyMember::ROLES.map { |r| [t("family_member.roles.#{r}"), r] }, family_member.role),
        include_blank: "Papel",
        class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  <%= text_field_tag "family_member[notes]", family_member.notes, placeholder: "Observações",
        class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  <%= submit_tag "Adicionar",
        class: "px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm cursor-pointer whitespace-nowrap" %>
<% end %>
