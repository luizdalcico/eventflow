<%# Um familiar na página pública (edição inline + remover). Locals: family_member, list. %>
<% editable = list.editable? %>
<%= form_with url: family_member_list_member_path(list.token, family_member), method: :patch, id: dom_id(family_member),
      data: { controller: "autosave" },
      class: "bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-3 flex items-center gap-3" do |f| %>
  <%= f.text_field "family_member[name]", value: family_member.name, disabled: !editable,
        data: { action: "input->autosave#save" },
        class: "flex-1 min-w-0 bg-transparent border-0 px-2 py-1 text-sm text-gray-800 focus:bg-blue-50 focus:outline-none rounded disabled:text-gray-500" %>
  <%= f.select "family_member[role]",
        options_for_select(FamilyMember::ROLES.map { |r| [t("family_member.roles.#{r}"), r] }, family_member.role),
        { include_blank: "—" },
        disabled: !editable,
        data: { action: "change->autosave#save" },
        class: "shrink-0 w-40 bg-transparent border-0 px-2 py-1 text-sm text-gray-600 focus:bg-blue-50 focus:outline-none rounded disabled:text-gray-500" %>
  <%= f.text_field "family_member[notes]", value: family_member.notes, placeholder: "Observações", disabled: !editable,
        data: { action: "input->autosave#save" },
        class: "flex-1 min-w-0 bg-transparent border-0 px-2 py-1 text-sm text-gray-600 focus:bg-blue-50 focus:outline-none rounded disabled:text-gray-500" %>
  <% if editable %>
    <%= link_to "×", family_member_list_member_path(list.token, family_member), title: "Remover",
          data: { turbo_method: :delete, turbo_confirm: "Remover este familiar?" },
          class: "shrink-0 text-gray-400 hover:text-red-600 text-lg leading-none px-1" %>
  <% end %>
<% end %>
