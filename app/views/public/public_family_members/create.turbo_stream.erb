<%= turbo_stream.remove "family_members_empty" %>
<%= turbo_stream.append "family_members" do %>
  <%= render partial: "family_members/family_member", locals: {
        family_member: @family_member,
        update_url: family_member_list_member_path(@list.token, @family_member),
        delete_url: family_member_list_member_path(@list.token, @family_member)
      } %>
<% end %>
<%= turbo_stream.replace "new_family_member" do %>
  <%= render "family_members/form", create_url: family_member_list_members_path(@list.token), family_member: @event.family_members.new %>
<% end %>
