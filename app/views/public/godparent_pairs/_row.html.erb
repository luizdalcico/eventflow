<%#
  Uma linha (par) da tabela de padrinhos.
  Desktop: célula de planilha (Excel), tudo visível.
  Mobile: card colapsável — mostra só os nomes; toca pra abrir e editar.
  Locals: `madrinha` (Guest âncora), `list` (GodparentList).
%>
<% padrinho = madrinha.pair %>
<% editable = list.editable? %>
<%# No load inicial tudo começa colapsado; só o par recém-adicionado vem aberto. %>
<% collapsed = !local_assigns.fetch(:expanded, false) %>
<%
  detail = "#{collapsed ? 'hidden' : 'block'} md:table-cell align-top border-b border-gray-100 " \
           "last:border-b-0 md:border md:border-gray-300 md:last:border-b"
  field  = "w-full bg-transparent px-2 py-1.5 text-sm text-gray-800 placeholder-gray-400 " \
           "border-0 focus:bg-blue-50 focus:outline-none disabled:text-gray-500"
  label  = "md:hidden block text-[11px] font-medium text-gray-500 px-2 pt-1.5"
  side_opts     = [["Noiva", "noiva"], ["Noivo", "noivo"], ["Sem Lado", "sem_lado"]]
  relation_opts = [["Irmã(o)", "irmao"], ["Amigo(a)", "amigo"], ["Avô(ó)", "avo"], ["Primo(a)", "primo"], ["Outro", "outro"]]
  pair_opts     = Godparent::RELATIONSHIPS.map { |r| [t("godparent.relationships.#{r}"), r] }
  act           = { action: "input->godparent-row#save change->godparent-row#save" }
%>

<tr id="pair_<%= madrinha.id %>"
    data-controller="godparent-row pair-collapse"
    data-godparent-row-id-value="<%= madrinha.id %>"
    data-godparent-row-token-value="<%= list.token %>"
    class="block md:table-row bg-white border border-gray-300 md:border-0 rounded-lg md:rounded-none mb-4 md:mb-0">

  <%# Resumo (só mobile) — clique pra abrir/fechar %>
  <td class="md:hidden block px-3 py-3 cursor-pointer select-none" data-action="click->pair-collapse#toggle">
    <div class="flex items-center justify-between gap-2">
      <span class="text-sm text-gray-800">
        <span class="font-semibold text-gray-400">#<%= madrinha.position %></span>
        <span class="font-medium"><%= madrinha.name.presence || "—" %></span>
        <span class="text-gray-400">&amp;</span>
        <span class="font-medium"><%= padrinho&.name.presence || "—" %></span>
      </span>
      <span data-pair-collapse-target="chevron"
            class="text-gray-400 transition-transform <%= "rotate-180" unless collapsed %>">▾</span>
    </div>
  </td>

  <%# Ordem (só desktop) %>
  <td class="hidden md:table-cell md:border md:border-gray-300 md:w-10 md:text-center md:text-xs md:text-gray-400 md:align-middle">
    <%= madrinha.position %>
  </td>

  <%# 1) Lado %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Lado</span>
    <%= select_tag "pair[side]", options_for_select(side_opts, madrinha.side), include_blank: "Selecione…", disabled: !editable, class: field, data: act %>
  </td>

  <%# 2) Madrinha %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %> text-pink-600">Madrinha</span>
    <%= text_field_tag "pair[madrinha][name]", madrinha.name, placeholder: "Nome Sobrenome", disabled: !editable, class: "#{field} font-medium", data: act %>
  </td>

  <%# 3) Telefone (madrinha) %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Telefone</span>
    <%= text_field_tag "pair[madrinha][phone_number]", madrinha.phone_number, placeholder: "(00) 00000-0000", disabled: !editable,
          class: field, data: act.merge(controller: "simple-mask", simple_mask_pattern_value: "(00) 00000-0000") %>
  </td>

  <%# 4) Relação (madrinha) %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Relação</span>
    <%= select_tag "pair[madrinha][relation]", options_for_select(relation_opts, madrinha.relation), include_blank: "Selecione…", disabled: !editable, class: field, data: act %>
  </td>

  <%# 5) Padrinho %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %> text-blue-600">Padrinho</span>
    <%= text_field_tag "pair[padrinho][name]", padrinho&.name, placeholder: "Nome Sobrenome", disabled: !editable, class: "#{field} font-medium", data: act %>
  </td>

  <%# 6) Telefone (padrinho) %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Telefone</span>
    <%= text_field_tag "pair[padrinho][phone_number]", padrinho&.phone_number, placeholder: "(00) 00000-0000", disabled: !editable,
          class: field, data: act.merge(controller: "simple-mask", simple_mask_pattern_value: "(00) 00000-0000") %>
  </td>

  <%# 7) Relação (padrinho) %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Relação</span>
    <%= select_tag "pair[padrinho][relation]", options_for_select(relation_opts, padrinho&.relation), include_blank: "Selecione…", disabled: !editable, class: field, data: act %>
  </td>

  <%# 8) Os padrinhos são %>
  <td class="<%= detail %>" data-pair-collapse-target="detail">
    <span class="<%= label %>">Os padrinhos são</span>
    <%= select_tag "pair[relationship]", options_for_select(pair_opts, madrinha.relationship), include_blank: "Selecione…", disabled: !editable, class: field, data: act %>
  </td>

  <%# Remover %>
  <td class="<%= detail %> md:w-8 md:text-center md:align-middle" data-pair-collapse-target="detail">
    <% if editable %>
      <%= link_to godparent_list_pair_path(list.token, madrinha),
            data: { turbo_method: :delete },
            class: "inline-block px-2 py-1.5 md:p-0 text-gray-400 hover:text-red-600 text-sm" do %>
        <span class="md:hidden">× Remover par</span>
        <span class="hidden md:inline text-lg leading-none" title="Remover par">×</span>
      <% end %>
    <% end %>
  </td>
</tr>
