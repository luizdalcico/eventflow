<%# Form de novo familiar na página pública. Locals: list, family_member (novo). %>
<%= form_with url: family_member_list_members_path(list.token), id: "new_public_family_member",
      class: "bg-white rounded-xl ring-1 ring-gray-200 shadow-sm p-4 flex flex-col sm:flex-row gap-3" do |f| %>
  <%= f.text_field "family_member[name]", value: family_member.name, placeholder: "Nome", required: true,
        class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  <%= f.select "family_member[role]",
        options_for_select(FamilyMember::ROLES.map { |r| [t("family_member.roles.#{r}"), r] }, family_member.role),
        { include_blank: "Papel" },
        class: "border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  <%= f.text_field "family_member[notes]", value: family_member.notes, placeholder: "Observações",
        class: "flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  <%= f.submit "Adicionar",
        class: "px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm cursor-pointer whitespace-nowrap" %>
<% end %>
